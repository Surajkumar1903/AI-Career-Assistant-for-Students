# Copy to `.env` and adjust values for your machine.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///database.db

# Optional AI providers (chatbot, Job-Based AI Resume Builder JSON, richer text)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional outbound email (contact notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# Login / Register “Continue with Google / LinkedIn” (full URLs; set to your OAuth authorize URLs when ready)
SOCIAL_GOOGLE_URL=https://accounts.google.com/
SOCIAL_LINKEDIN_URL=https://www.linkedin.com/
